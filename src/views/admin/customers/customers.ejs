<!-- Title -->
<div class="mb-8 flex items-center justify-between">
  <h1 class="text-2xl font-serif font-bold text-brand-black flex items-center gap-2">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
    </svg>
    Customer Management
  </h1>
</div>

<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-6 mb-8">
  <!-- Total -->
  <div class="bg-white p-6 border border-brand-gray-100 rounded-xl shadow-sm flex flex-col justify-between">
    <div class="flex items-start justify-between mb-2">
      <p class="font-sans text-sm text-brand-gray-500">Total<br>Customers</p>
      <div class="p-2 bg-brand-gray-50 rounded-full">
        <svg class="w-4 h-4 text-brand-gray-600" fill="currentColor" viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
      </div>
    </div>
    <h3 class="font-serif text-4xl font-bold text-brand-black"><%= stats.total %></h3>
  </div>

  <!-- Active -->
  <div class="bg-white p-6 border border-brand-gray-100 rounded-xl shadow-sm flex flex-col justify-between">
    <div class="flex items-start justify-between mb-2">
      <p class="font-sans text-sm text-brand-gray-500">Active Users</p>
      <div class="p-2 bg-green-50 rounded-full flex items-center justify-center">
        <div class="w-2.5 h-2.5 bg-green-500 rounded-full"></div>
      </div>
    </div>
    <h3 class="font-serif text-4xl font-bold text-brand-black"><%= stats.active %></h3>
  </div>

  <!-- Blocked -->
  <div class="bg-white p-6 border border-brand-gray-100 rounded-xl shadow-sm flex flex-col justify-between">
    <div class="flex items-start justify-between mb-2">
      <p class="font-sans text-sm text-brand-gray-500">Blocked Users</p>
      <div class="p-2 bg-red-50 rounded-full">
        <svg class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
      </div>
    </div>
    <h3 class="font-serif text-4xl font-bold text-brand-black"><%= stats.blocked %></h3>
  </div>
</div>

<!-- Customer Directory -->
<div class="bg-white border border-brand-gray-100 rounded-xl shadow-sm overflow-hidden">
  <div class="p-6 border-b border-brand-gray-100">
    <h2 class="font-serif text-xl font-bold text-brand-black mb-6">Customer Directory</h2>
    
    <form id="filter-form" action="/admin/customers" method="GET" class="flex flex-col sm:flex-row gap-4">
      <!-- Search Input -->
      <div class="relative flex-1">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="w-5 h-5 text-brand-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input type="text" id="search-input" name="search" value="<%= searchQuery || '' %>" placeholder="Search user by name or email..." 
               class="w-full pl-10 pr-10 py-2.5 bg-white border border-brand-gray-200 rounded-md font-sans text-sm focus:outline-none focus:ring-1 focus:ring-brand-black focus:border-brand-black">
        <% if (searchQuery) { %>
          <button type="button" id="clear-search-btn" class="absolute inset-y-0 right-0 pr-3 flex items-center text-brand-gray-400 hover:text-brand-black" title="Clear search">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        <% } %>
      </div>
      
      <!-- Status Filter -->
      <div class="relative w-full sm:w-48">
        <select id="status-filter" name="status" class="w-full pl-4 pr-10 py-2.5 bg-white border border-brand-gray-200 rounded-md font-sans text-sm focus:outline-none focus:ring-1 focus:ring-brand-black focus:border-brand-black appearance-none">
          <option value="All Status" <%= statusFilter === 'All Status' ? 'selected' : '' %>>All Status</option>
          <option value="Active" <%= statusFilter === 'Active' ? 'selected' : '' %>>Active</option>
          <option value="Blocked" <%= statusFilter === 'Blocked' ? 'selected' : '' %>>Blocked</option>
        </select>
        <!-- Custom dropdown arrow -->
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-brand-gray-400">
          <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
            <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/>
          </svg>
        </div>
      </div>
      
      <div class="flex gap-2 w-full sm:w-auto">
        <!-- Search Button -->
        <button type="submit" class="flex-1 sm:flex-initial bg-brand-black text-white px-6 py-2.5 rounded-md font-sans font-medium text-sm hover:bg-brand-gray-600 transition-colors">
          Search
        </button>
        
        <% if (searchQuery || statusFilter !== 'All Status') { %>
          <!-- Clear Filters Button -->
          <a href="/admin/customers" class="flex-1 sm:flex-initial bg-brand-gray-100 text-brand-black border border-brand-gray-200 px-6 py-2.5 rounded-md font-sans font-medium text-sm hover:bg-brand-gray-200 transition-colors flex items-center justify-center" title="Clear all search and filters">
            Clear Filters
          </a>
        <% } %>
      </div>
    </form>
  </div>

  <!-- Mobile Card View (visible on < md screens) -->
  <div class="block md:hidden divide-y divide-brand-gray-100">
    <% if (customers && customers.length > 0) { %>
      <% customers.forEach(customer => { %>
        <div class="p-5 flex flex-col gap-4 hover:bg-brand-gray-50 transition-colors">
          <!-- User Profile info -->
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full overflow-hidden bg-brand-gray-100 flex-shrink-0">
              <% if (customer.profileImage) { %>
                <img src="<%= customer.profileImage %>" alt="Profile" class="w-full h-full object-cover" referrerpolicy="no-referrer">
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center font-serif text-lg font-bold text-brand-gray-400 bg-brand-gray-200">
                  <%= customer.fullName.charAt(0).toUpperCase() %>
                </div>
              <% } %>
            </div>
            <div class="min-w-0 flex-1">
              <div class="font-sans font-semibold text-brand-black text-sm truncate"><%= customer.fullName %></div>
              <div class="font-sans text-xs text-brand-gray-500 truncate"><%= customer.email %></div>
            </div>
          </div>
          
          <!-- Metadata & Status -->
          <div class="flex items-center justify-between text-xs pt-2 border-t border-brand-gray-50">
            <div>
              <span class="block text-[10px] text-brand-gray-400 uppercase tracking-wider">Joined Date</span>
              <span class="font-medium text-brand-black"><%= new Date(customer.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></span>
            </div>
            
            <div class="text-right">
              <span class="block text-[10px] text-brand-gray-400 uppercase tracking-wider mb-1">Status</span>
              <span id="status-badge-mobile-<%= customer._id %>" class="px-2.5 py-0.5 inline-flex text-[10px] leading-5 font-semibold rounded-md 
                <%= customer.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                <%= customer.status === 'active' ? 'Active' : 'Blocked' %>
              </span>
            </div>
          </div>
          
          <!-- Actions -->
          <div class="pt-2">
            <button class="toggle-status-btn w-full py-2.5 rounded-md text-xs font-semibold text-white transition-colors
              <%= customer.status === 'active' ? 'bg-red-600 hover:bg-red-700' : 'bg-green-600 hover:bg-green-700' %>"
              data-id="<%= customer._id %>"
              data-current-status="<%= customer.status %>">
              <%= customer.status === 'active' ? 'Block Customer' : 'Unblock Customer' %>
            </button>
          </div>
        </div>
      <% }); %>
    <% } else { %>
      <div class="p-8 text-center text-brand-gray-400 font-sans text-sm">
        No customers found.
      </div>
    <% } %>
  </div>

  <!-- Desktop Table View (visible on >= md screens) -->
  <div class="hidden md:block overflow-x-auto">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="border-b border-brand-gray-100">
          <th class="px-6 py-4 font-sans text-xs font-semibold text-brand-gray-500 uppercase tracking-wider">User</th>
          <th class="px-6 py-4 font-sans text-xs font-semibold text-brand-gray-500 uppercase tracking-wider">Email</th>
          <th class="px-6 py-4 font-sans text-xs font-semibold text-brand-gray-500 uppercase tracking-wider">Joined Date</th>
          <th class="px-6 py-4 font-sans text-xs font-semibold text-brand-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-4 font-sans text-xs font-semibold text-brand-gray-500 uppercase tracking-wider text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-brand-gray-50">
        <% if (customers && customers.length > 0) { %>
          <% customers.forEach(customer => { %>
            <tr class="hover:bg-brand-gray-50 transition-colors">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full overflow-hidden bg-brand-gray-100 flex-shrink-0">
                    <% if (customer.profileImage) { %>
                      <img src="<%= customer.profileImage %>" alt="Profile" class="w-full h-full object-cover" referrerpolicy="no-referrer">
                    <% } else { %>
                      <div class="w-full h-full flex items-center justify-center font-serif text-lg font-bold text-brand-gray-400 bg-brand-gray-200">
                        <%= customer.fullName.charAt(0).toUpperCase() %>
                      </div>
                    <% } %>
                  </div>
                  <div class="font-sans font-medium text-brand-black text-sm"><%= customer.fullName %></div>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap font-sans text-sm text-brand-gray-500">
                <%= customer.email %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap font-sans text-sm text-brand-gray-500">
                <%= new Date(customer.createdAt).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span id="status-badge-<%= customer._id %>" class="px-3 py-1 inline-flex text-[11px] leading-5 font-semibold rounded-md 
                  <%= customer.status === 'active' ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                  <%= customer.status === 'active' ? 'Active' : 'Blocked' %>
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right">
                <button class="toggle-status-btn px-6 py-1.5 rounded-full text-xs font-semibold text-white transition-colors
                  <%= customer.status === 'active' ? 'bg-red-600 hover:bg-red-700' : 'bg-green-600 hover:bg-green-700' %>"
                  data-id="<%= customer._id %>"
                  data-current-status="<%= customer.status %>">
                  <%= customer.status === 'active' ? 'Block' : 'Unblock' %>
                </button>
              </td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr>
            <td colspan="5" class="px-6 py-12 text-center text-brand-gray-400 font-sans text-sm">
              No customers found.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <% if (totalPages > 1) { %>
    <div class="px-6 py-4 border-t border-brand-gray-100 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-sans text-sm text-brand-gray-500 text-center sm:text-left">
        Showing <%= ((currentPage - 1) * 10) + 1 %> to <%= Math.min(currentPage * 10, totalEntries) %> of <%= totalEntries %> entries
      </p>
      
      <div class="flex items-center justify-between w-full sm:w-auto gap-2">
        <% if (currentPage > 1) { %>
          <a href="?page=<%= currentPage - 1 %>&search=<%= searchQuery %>&status=<%= statusFilter %>" class="px-3 py-1.5 border border-brand-gray-200 rounded-md text-brand-gray-600 hover:bg-brand-gray-50 transition-colors flex items-center gap-1 text-xs sm:text-sm">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            Previous
          </a>
        <% } else { %>
          <span class="px-3 py-1.5 border border-brand-gray-200 rounded-md text-brand-gray-300 flex items-center gap-1 cursor-not-allowed text-xs sm:text-sm">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            Previous
          </span>
        <% } %>

        <!-- Page Numbers: Hidden on extra small mobile screens, shown on sm and up -->
        <div class="hidden sm:flex items-center gap-1">
          <% for(let i = 1; i <= totalPages; i++) { %>
            <% if (i === currentPage) { %>
              <span class="w-8 h-8 flex items-center justify-center bg-brand-gray-100 rounded-md font-medium text-brand-black"><%= i %></span>
            <% } else if (i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) { %>
              <a href="?page=<%= i %>&search=<%= searchQuery %>&status=<%= statusFilter %>" class="w-8 h-8 flex items-center justify-center border border-brand-gray-200 rounded-md text-brand-gray-600 hover:bg-brand-gray-50 transition-colors"><%= i %></a>
            <% } else if (i === currentPage - 2 || i === currentPage + 2) { %>
              <span class="w-8 h-8 flex items-center justify-center text-brand-gray-400">...</span>
            <% } %>
          <% } %>
        </div>

        <!-- Mobile Page Indicator -->
        <span class="sm:hidden font-sans text-xs text-brand-gray-500 font-medium">
          Page <%= currentPage %> of <%= totalPages %>
        </span>

        <% if (currentPage < totalPages) { %>
          <a href="?page=<%= currentPage + 1 %>&search=<%= searchQuery %>&status=<%= statusFilter %>" class="px-3 py-1.5 border border-brand-gray-200 rounded-md text-brand-gray-600 hover:bg-brand-gray-50 transition-colors flex items-center gap-1 text-xs sm:text-sm">
            Next
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        <% } else { %>
          <span class="px-3 py-1.5 border border-brand-gray-200 rounded-md text-brand-gray-300 flex items-center gap-1 cursor-not-allowed text-xs sm:text-sm">
            Next
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </span>
        <% } %>
      </div>
    </div>
  <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // Filter form auto-submit & clear logic
  const statusFilterSelect = document.getElementById('status-filter');
  if (statusFilterSelect) {
    statusFilterSelect.addEventListener('change', () => {
      document.getElementById('filter-form').submit();
    });
  }

  const clearSearchBtn = document.getElementById('clear-search-btn');
  if (clearSearchBtn) {
    clearSearchBtn.addEventListener('click', () => {
      document.getElementById('search-input').value = '';
      document.getElementById('filter-form').submit();
    });
  }

  // Toggle user status block/unblock
  document.querySelectorAll('.toggle-status-btn').forEach(button => {
    button.addEventListener('click', async function() {
      const userId = this.getAttribute('data-id');
      const currentStatus = this.getAttribute('data-current-status');
      const actionText = currentStatus === 'active' ? 'block' : 'unblock';
      const actionTitle = actionText.charAt(0).toUpperCase() + actionText.slice(1);
      
      const confirmColor = currentStatus === 'active' ? '#dc2626' : '#16a34a'; // Red / Green

      const result = await Swal.fire({
        title: `${actionTitle} User?`,
        text: `Are you sure you want to ${actionText} this customer?`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: confirmColor,
        cancelButtonColor: '#6b7280',
        confirmButtonText: `Yes, ${actionText} it!`,
        customClass: {
          popup: 'rounded-xl',
        }
      });

      if (result.isConfirmed) {
        try {
          const response = await axios.post(`/admin/customers/toggle-status/${userId}`);
          if (response.data.success) {
            Swal.fire({
              title: 'Success!',
              text: `Customer has been ${response.data.newStatus}d.`,
              icon: 'success',
              timer: 1500,
              showConfirmButton: false
            }).then(() => {
              window.location.reload();
            });
          }
        } catch (error) {
          Swal.fire({
            title: 'Error!',
            text: error.response?.data?.message || 'Something went wrong.',
            icon: 'error'
          });
        }
      }
    });
  });
</script>

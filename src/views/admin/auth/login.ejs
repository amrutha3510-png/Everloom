<main class="min-h-screen bg-brand-gray-50 flex flex-col items-center justify-center px-4 py-8 sm:py-16">

  <!-- Logo and Pill -->
  <div class="mb-10 text-center">
    <div class="flex items-center justify-center gap-2 mb-4">
      <svg class="w-6 h-6 text-brand-black" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M11.25 2.08299C11.0043 2.13811 10.7652 2.21958 10.537 2.32599C6.553 4.18799 4 9.39499 4 13.856C4 18.096 7.183 21.58 11.25 21.965V2.08299Z" fill="currentColor"/>
        <path d="M12.75 21.965C16.817 21.58 20 18.097 20 13.857C20 13.4503 19.979 13.039 19.937 12.623L12.75 19.811V21.965Z" fill="currentColor"/>
        <path d="M18.26 7.17999C17.8763 6.46064 17.4278 5.77781 16.92 5.13999L12.75 9.30999V12.69L18.26 7.17999Z" fill="currentColor"/>
        <path d="M15.908 4.02999C15.191 3.33289 14.3652 2.75734 13.463 2.32599C13.2348 2.21958 12.9957 2.13811 12.75 2.08299V7.18899L15.908 4.02999Z" fill="currentColor"/>
        <path d="M18.936 8.62399L12.75 14.811V17.689L19.5 10.939L19.632 10.807C19.456 10.0626 19.2233 9.33285 18.936 8.62399Z" fill="currentColor"/>
      </svg>
      <span class="font-serif text-2xl font-bold tracking-wide">Everloom</span>
    </div>
    <span class="inline-block bg-brand-gray-200 text-brand-gray-600 text-[10px] font-sans font-bold tracking-widest2 uppercase px-4 py-1.5 rounded-full">
      ADMIN PANEL
    </span>
  </div>

  <div class="w-full max-w-md sm:max-w-lg bg-white px-5 py-8 sm:px-12 sm:py-14 shadow-sm border border-brand-gray-50 rounded-sm mb-6">
    <h1 class="font-serif text-3xl sm:text-4xl font-bold text-brand-black text-left leading-tight mb-3">
      Welcome Back
    </h1>

    <p class="font-sans text-xs sm:text-sm text-brand-gray-600 text-left leading-relaxed mb-8 sm:mb-10">
      Sign in to manage products, orders, customers, and store analytics.
    </p>

    <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
      <div class="bg-red-50 border border-red-200 text-red-600 text-xs sm:text-sm px-4 py-3 rounded mb-4 font-sans text-left">
        <%= errorMessage %>
      </div>
    <% } %>

    <form action="/admin/login" method="POST" id="loginForm" novalidate class="space-y-6">

      <div>
        <label for="email" class="block font-sans text-xs font-semibold text-brand-gray-600 mb-2">Email Address</label>
        <input
          type="email"
          name="email"
          id="email"
          placeholder="Enter your admin email"
          autocomplete="email"
          value="<%= typeof oldData !== 'undefined' ? oldData.email : '' %>"
          required
          class="
            w-full bg-white border border-brand-gray-200
            text-brand-black placeholder-brand-gray-400
            font-sans text-sm px-4 py-3.5 rounded-sm
            focus:outline-none focus:border-brand-gray-600
            transition-all duration-150
          "
        />
        <p class="hidden text-red-500 text-xs mt-1.5 font-sans pl-1" id="emailError"></p>
      </div>

      <div class="relative">
        <label for="password" class="block font-sans text-xs font-semibold text-brand-gray-600 mb-2">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          placeholder="Enter your password"
          autocomplete="current-password"
          required
          class="
            w-full bg-white border border-brand-gray-200
            text-brand-black placeholder-brand-gray-400
            font-sans text-sm px-4 py-3.5 pr-12 rounded-sm
            focus:outline-none focus:border-brand-gray-600
            transition-all duration-150
          "
        />
        <button
          type="button"
          onclick="togglePassword('password', 'eyeIcon')"
          class="absolute right-4 bottom-3.5 text-brand-gray-400 hover:text-brand-gray-600 transition-colors"
          aria-label="Toggle password visibility"
        >
          <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </button>
        <p class="hidden text-red-500 text-xs mt-1.5 font-sans pl-1" id="passwordError"></p>
      </div>

      <div class="pt-4">
        <button
          type="submit"
          class="
            w-full bg-brand-black text-white
            font-sans text-sm font-medium
            px-6 py-4 rounded-sm
            hover:bg-brand-gray-600
            active:scale-[0.99]
            transition-all duration-150
            flex items-center justify-center gap-2
          "
        >
          Login to Dashboard
        </button>
      </div>
    </form>
  </div>

  <div class="w-full max-w-md sm:max-w-lg bg-transparent px-5 py-6 sm:px-12 border border-brand-gray-100 rounded-sm flex flex-col items-center text-center">
    <div class="bg-brand-gray-200 p-2 rounded-full mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-black" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 1.944A11.954 11.954 0 012.166 5C2.056 5.642 2 6.319 2 7c0 5.225 3.34 9.67 8 11.317C14.66 16.67 18 12.225 18 7c0-.682-.057-1.358-.166-2.001A11.954 11.954 0 0110 1.944zM10 14a4 4 0 100-8 4 4 0 000 8zm0-6a2 2 0 110 4 2 2 0 010-4z" clip-rule="evenodd" />
      </svg>
    </div>
    <h3 class="font-sans text-sm font-bold text-brand-black mb-1">Protected Admin Access</h3>
    <p class="font-sans text-xs text-brand-gray-400">
      Only authorized administrators can access the<br>Everloom management panel.
    </p>
  </div>

</main>

<script>
  function togglePassword(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon  = document.getElementById(iconId);
    if (!input || !icon) return;

    const isPassword = input.type === 'password';
    input.type = isPassword ? 'text' : 'password';

    if (isPassword) {
      icon.innerHTML = `
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
      `;
    } else {
      icon.innerHTML = `
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      `;
    }
  }

  document.getElementById('loginForm').addEventListener('submit', function (e) {
    let isValid = true;

    const email    = document.getElementById('email');
    const password = document.getElementById('password');

    const setInvalid = (inputEl, errorElId, msg) => {
      const errorEl = document.getElementById(errorElId);
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
      
      inputEl.classList.remove('border-brand-gray-200', 'focus:border-brand-gray-600');
      inputEl.classList.add('border-red-500', 'focus:border-red-500');
      isValid = false;
    };

    const setValid = (inputEl, errorElId) => {
      const errorEl = document.getElementById(errorElId);
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
      
      inputEl.classList.remove('border-red-500', 'focus:border-red-500');
      inputEl.classList.add('border-brand-gray-200', 'focus:border-brand-gray-600');
    };

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!email.value.trim()) {
      setInvalid(email, 'emailError', 'Please enter your email address.');
    } else if (!emailRegex.test(email.value.trim())) {
      setInvalid(email, 'emailError', 'Please enter a valid email address.');
    } else {
      setValid(email, 'emailError');
    }

    if (!password.value) {
      setInvalid(password, 'passwordError', 'Please enter your password.');
    } else {
      setValid(password, 'passwordError');
    }

    if (!isValid) {
      e.preventDefault();
    }
  });

  ['email', 'password'].forEach(id => {
    document.getElementById(id).addEventListener('input', function() {
      this.classList.remove('border-red-500', 'focus:border-red-500');
      this.classList.add('border-brand-gray-200', 'focus:border-brand-gray-600');
      const errorEl = document.getElementById(id + 'Error');
      if (errorEl) errorEl.classList.add('hidden');
    });
  });
</script>

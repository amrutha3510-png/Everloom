<main class="min-h-screen bg-brand-gray-50 flex items-center justify-center px-4 py-12 sm:py-16">

  <div class="w-full max-w-md sm:max-w-lg bg-white px-5 py-8 sm:px-12 sm:py-14 shadow-sm border border-brand-gray-50 rounded-sm">

    <h1 class="font-serif text-3xl sm:text-5xl font-bold text-brand-black text-center leading-tight mb-3">
      Set New Password
    </h1>

    <p class="font-sans text-xs sm:text-sm text-brand-gray-600 text-center leading-relaxed mb-8 sm:mb-10">
      Create a strong new password for your account.<br class="hidden sm:block" />
      Must be at least 8 characters with 1 uppercase, 1 lowercase, 1 number, and 1 special character.
    </p>

    <form
      action="/set-new-password"
      method="POST"
      id="resetForm"
      novalidate
      class="space-y-4"
    >

      <div class="relative">
        <input
          type="password"
          name="newPassword"
          id="newPassword"
          placeholder="New Password *"
          autocomplete="new-password"
          required
          class="
            w-full bg-brand-gray-50 border border-brand-gray-100
            text-brand-black placeholder-brand-gray-400
            font-sans text-sm px-4 py-3.5 pr-12
            focus:outline-none focus:border-brand-gray-600 focus:bg-white
            transition-all duration-150
          "
        />
        <button
          type="button"
          onclick="togglePassword('newPassword', 'eyeIcon1')"
          class="absolute right-4 top-[22px] -translate-y-1/2 text-brand-gray-400 hover:text-brand-gray-600 transition-colors"
          aria-label="Toggle password visibility"
        >
          <svg id="eyeIcon1" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </button>
        <p class="hidden text-red-500 text-xs mt-1.5 font-sans pl-1" id="newPasswordError"></p>
      </div>

      <div class="relative">
        <input
          type="password"
          name="confirmNewPassword"
          id="confirmNewPassword"
          placeholder="Confirm New Password *"
          autocomplete="new-password"
          required
          class="
            w-full bg-brand-gray-50 border border-brand-gray-100
            text-brand-black placeholder-brand-gray-400
            font-sans text-sm px-4 py-3.5 pr-12
            focus:outline-none focus:border-brand-gray-600 focus:bg-white
            transition-all duration-150
          "
        />
        <button
          type="button"
          onclick="togglePassword('confirmNewPassword', 'eyeIcon2')"
          class="absolute right-4 top-[22px] -translate-y-1/2 text-brand-gray-400 hover:text-brand-gray-600 transition-colors"
          aria-label="Toggle confirm password visibility"
        >
          <svg id="eyeIcon2" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </button>
        <p class="hidden text-red-500 text-xs mt-1.5 font-sans pl-1" id="confirmNewPasswordError"></p>
      </div>

      <div class="pt-2">
        <button
          type="submit"
          class="
            w-full bg-brand-black text-white
            font-sans text-xs font-semibold tracking-widest2 uppercase
            px-6 py-3.5 sm:py-4
            hover:bg-brand-gray-600
            active:scale-[0.99]
            transition-all duration-150
            flex items-center justify-center gap-2
          "
        >
          Reset Password
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
      </div>

    </form>

  </div>

</main>

<script>
  function togglePassword(inputId, iconId) {
    const input = document.getElementById(inputId);
    const icon  = document.getElementById(iconId);
    if (!input || !icon) return;

    const isPassword = input.type === 'password';
    input.type = isPassword ? 'text' : 'password';

    if (isPassword) {
      icon.innerHTML = `
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
      `;
    } else {
      icon.innerHTML = `
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      `;
    }
  }

  document.getElementById('resetForm').addEventListener('submit', function (e) {
    let isValid = true;

    const newPassword        = document.getElementById('newPassword');
    const confirmNewPassword = document.getElementById('confirmNewPassword');

    const setInvalid = (inputEl, errorElId, msg) => {
      const errorEl = document.getElementById(errorElId);
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
      inputEl.classList.remove('border-brand-gray-100', 'focus:border-brand-gray-600');
      inputEl.classList.add('border-red-500', 'focus:border-red-500');
      isValid = false;
    };

    const setValid = (inputEl, errorElId) => {
      const errorEl = document.getElementById(errorElId);
      errorEl.textContent = '';
      errorEl.classList.add('hidden');
      inputEl.classList.remove('border-red-500', 'focus:border-red-500');
      inputEl.classList.add('border-brand-gray-100', 'focus:border-brand-gray-600');
    };

    // Password validation (min 8 characters, 1 uppercase, 1 lowercase, 1 number, 1 special char)
    const passwordRegex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z\d]).{8,}$/;
    if (!newPassword.value) {
      setInvalid(newPassword, 'newPasswordError', 'Please enter a new password.');
    } else if (!passwordRegex.test(newPassword.value)) {
      setInvalid(newPassword, 'newPasswordError', 'Password must be at least 8 characters with 1 uppercase, 1 lowercase, 1 number, and 1 special character.');
    } else {
      setValid(newPassword, 'newPasswordError');
    }

    // Confirm password validation
    if (!confirmNewPassword.value) {
      setInvalid(confirmNewPassword, 'confirmNewPasswordError', 'Please confirm your new password.');
    } else if (newPassword.value !== confirmNewPassword.value) {
      setInvalid(confirmNewPassword, 'confirmNewPasswordError', 'Passwords do not match.');
    } else {
      setValid(confirmNewPassword, 'confirmNewPasswordError');
    }

    if (!isValid) {
      e.preventDefault();
    }
  });

  // Real-time error removal
  ['newPassword', 'confirmNewPassword'].forEach(id => {
    document.getElementById(id).addEventListener('input', function () {
      this.classList.remove('border-red-500', 'focus:border-red-500');
      this.classList.add('border-brand-gray-100', 'focus:border-brand-gray-600');
      const errorEl = document.getElementById(id + 'Error');
      if (errorEl) errorEl.classList.add('hidden');
    });
  });
</script>

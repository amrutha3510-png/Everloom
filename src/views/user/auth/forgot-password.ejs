<main class="min-h-screen bg-brand-gray-50 flex items-center justify-center px-4 py-12 sm:py-16">

  <div class="w-full max-w-md sm:max-w-lg bg-white px-5 py-8 sm:px-12 sm:py-14 shadow-sm border border-brand-gray-50 rounded-sm">

    <h1 class="font-serif text-3xl sm:text-5xl font-bold text-brand-black text-center leading-tight mb-3">
      Forgot Password
    </h1>

    <p class="font-sans text-xs sm:text-sm text-brand-gray-600 text-center leading-relaxed mb-8 sm:mb-10">
      Enter your registered email address and we'll<br class="hidden sm:block" />
      send you a verification code to reset your password.
    </p>

    <form
      action="/forgot-password"
      method="POST"
      id="forgotForm"
      novalidate
      class="space-y-4"
    >

      <div>
        <input
          type="email"
          name="email"
          id="email"
          placeholder="Email Address *"
          autocomplete="email"
          required
          class="
            w-full bg-brand-gray-50 border border-brand-gray-100
            text-brand-black placeholder-brand-gray-400
            font-sans text-sm px-4 py-3.5
            focus:outline-none focus:border-brand-gray-600 focus:bg-white
            transition-all duration-150
          "
        />
        <p class="hidden text-red-500 text-xs mt-1.5 font-sans pl-1" id="emailError"></p>
      </div>

      <div class="pt-2">
        <button
          type="submit"
          class="
            w-full bg-brand-black text-white
            font-sans text-xs font-semibold tracking-widest2 uppercase
            px-6 py-3.5 sm:py-4
            hover:bg-brand-gray-600
            active:scale-[0.99]
            transition-all duration-150
            flex items-center justify-center gap-2
          "
        >
          Send OTP
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
      </div>

    </form>

    <p class="text-center font-sans text-sm text-brand-gray-600 mt-6">
      Remember your password?
      <a href="/login" class="text-brand-black font-semibold hover:underline underline-offset-2 transition-all">
        Back to Login
      </a>
    </p>

  </div>

</main>

<script>
  document.getElementById('forgotForm').addEventListener('submit', function (e) {
    const email = document.getElementById('email');
    const emailError = document.getElementById('emailError');
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    if (!email.value.trim()) {
      e.preventDefault();
      emailError.textContent = 'Please enter your email address.';
      emailError.classList.remove('hidden');
      email.classList.remove('border-brand-gray-100', 'focus:border-brand-gray-600');
      email.classList.add('border-red-500', 'focus:border-red-500');
    } else if (!emailRegex.test(email.value.trim())) {
      e.preventDefault();
      emailError.textContent = 'Please enter a valid email address.';
      emailError.classList.remove('hidden');
      email.classList.remove('border-brand-gray-100', 'focus:border-brand-gray-600');
      email.classList.add('border-red-500', 'focus:border-red-500');
    } else {
      emailError.classList.add('hidden');
      email.classList.remove('border-red-500', 'focus:border-red-500');
      email.classList.add('border-brand-gray-100', 'focus:border-brand-gray-600');
    }
  });

  document.getElementById('email').addEventListener('input', function () {
    this.classList.remove('border-red-500', 'focus:border-red-500');
    this.classList.add('border-brand-gray-100', 'focus:border-brand-gray-600');
    const errorEl = document.getElementById('emailError');
    if (errorEl) errorEl.classList.add('hidden');
  });
</script>

<%- include('../partials/navbar') %>

<section class="relative w-full h-[65vh] sm:h-[80vh] bg-brand-gray-50 overflow-hidden flex items-center">
  <div class="absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=2070" 
      alt="New Season Minimalist Wardrobe" 
      class="w-full h-full object-cover object-center brightness-[0.93]"
    />
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="max-w-xl md:max-w-2xl">
      <span class="text-[10px] font-semibold uppercase tracking-widest2 text-brand-gray-600 block mb-2 sm:mb-4">
        New Season Collection
      </span>
      <h1 class="font-serif text-4xl sm:text-6xl lg:text-7xl font-bold text-brand-black leading-[1.1] mb-4 sm:mb-6">
        Timeless Fashion<br />For Modern Women
      </h1>
      <p class="font-sans text-xs sm:text-sm text-brand-gray-600 leading-relaxed mb-6 sm:mb-8 max-w-md">
        Discover elevated essentials, curated luxury, and effortless elegance designed for the contemporary wardrobe.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="/shop" class="bg-brand-black text-white text-[10px] font-bold uppercase tracking-widest2 px-6 py-3.5 hover:bg-brand-gray-600 transition-colors">
          Shop Collection
        </a>
        <a href="/lookbook" class="bg-white border border-brand-gray-200 text-brand-black text-[10px] font-bold uppercase tracking-widest2 px-6 py-3.5 hover:bg-brand-gray-50 transition-colors">
          Explore Lookbook
        </a>
      </div>
    </div>
  </div>
</section>

<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
  <h2 class="font-serif text-2xl sm:text-3xl font-bold text-center text-brand-black mb-10 sm:mb-14">
    Shop By Category
  </h2>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <a href="/shop?category=casual" class="group relative h-[450px] overflow-hidden bg-brand-gray-50">
      <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?q=80&w=1020" alt="Casual Wear" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
      <div class="absolute inset-0 bg-black/10 flex items-center justify-center">
        <span class="font-serif text-white text-lg font-bold uppercase tracking-widest px-4 py-2 border-b-2 border-transparent group-hover:border-white transition-all">Casual</span>
      </div>
    </a>

    <a href="/shop?category=formal" class="group relative h-[450px] overflow-hidden bg-brand-gray-50">
      <img src="https://images.unsplash.com/photo-1485968579580-b6d095142e6e?q=80&w=986" alt="Formals Wear" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
      <div class="absolute inset-0 bg-black/10 flex items-center justify-center">
        <span class="font-serif text-white text-lg font-bold uppercase tracking-widest px-4 py-2 border-b-2 border-transparent group-hover:border-white transition-all">Formals</span>
      </div>
    </a>

    <a href="/shop?category=ethnic" class="group relative h-[450px] overflow-hidden bg-brand-gray-50">
      <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?q=80&w=987" alt="Ethnic Wear" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
      <div class="absolute inset-0 bg-black/10 flex items-center justify-center">
        <span class="font-serif text-white text-lg font-bold uppercase tracking-widest px-4 py-2 border-b-2 border-transparent group-hover:border-white transition-all">Ethnic</span>
      </div>
    </a>
  </div>
</section>


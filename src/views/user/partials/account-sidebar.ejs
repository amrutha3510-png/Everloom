<%
  /*
   * account-sidebar.ejs
   * Usage: include('../partials/account-sidebar')
   * Requires: accountPage local variable ('profile' | 'addresses' | 'security' | 'wallet' | 'referrals')
   */
  const ap = typeof accountPage !== 'undefined' ? accountPage : '';
  const navItems = [
    {
      page: 'profile',
      label: 'Profile Information',
      href: '/account/profile',
      svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/>',
    },
    {
      page: 'addresses',
      label: 'Saved Addresses',
      href: '/account/addresses',
      svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>',
    },
    {
      page: 'security',
      label: 'Security Settings',
      href: '/account/security',
      svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>',
    },
    {
      page: 'wallet',
      label: 'My Wallet',
      href: '/account/wallet',
      svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18-3a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6"/>',
    },
    {
      page: 'referrals',
      label: 'My Referrals',
      href: '/account/referrals',
      svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 100 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186l9.566-5.314m-9.566 7.5l9.566 5.314m0 0a2.25 2.25 0 103.935 2.186 2.25 2.25 0 00-3.935-2.186zm0-12.814a2.25 2.25 0 103.933-2.185 2.25 2.25 0 00-3.933 2.185z"/>',
    },
  ];
%>
<aside class="w-full lg:w-56 flex-shrink-0">
  <nav class="bg-white border border-brand-gray-100">
    <% navItems.forEach(item => {
         const isActive = ap === item.page;
    %>
      <a href="<%= item.href %>"
         class="flex items-center gap-3 px-5 py-3.5 border-b border-brand-gray-100 last:border-b-0 text-xs font-medium uppercase tracking-widest transition-colors
                <%= isActive ? 'bg-brand-black text-white' : 'text-brand-gray-600 hover:bg-brand-gray-50 hover:text-brand-black' %>">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <%- item.svg %>
        </svg>
        <%= item.label %>
      </a>
    <% }); %>
  </nav>

  <!-- Sign Out -->
  <form action="/logout" method="POST" class="mt-4">
    <button type="submit"
            class="w-full flex items-center gap-3 px-5 py-3.5 bg-white border border-brand-gray-100 text-xs font-medium uppercase tracking-widest text-brand-gray-600 hover:bg-brand-gray-50 hover:text-brand-black transition-colors">
      <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75"/>
      </svg>
      Sign Out
    </button>
  </form>
</aside>

<footer class="bg-black text-white pt-12 pb-8 sm:pt-16 sm:pb-12 font-sans">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12 pb-12 border-b border-zinc-800">
      
      <div class="space-y-4">
        <h2 class="flex items-center gap-2 font-serif text-3xl font-bold tracking-wide">
          <svg class="w-8 h-8 text-white animate-pulse" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M11.25 2.08299C11.0043 2.13811 10.7652 2.21958 10.537 2.32599C6.553 4.18799 4 9.39499 4 13.856C4 18.096 7.183 21.58 11.25 21.965V2.08299Z" fill="currentColor"/>
            <path d="M12.75 21.965C16.817 21.58 20 18.097 20 13.857C20 13.4503 19.979 13.039 19.937 12.623L12.75 19.811V21.965Z" fill="currentColor"/>
            <path d="M18.26 7.17999C17.8763 6.46064 17.4278 5.77781 16.92 5.13999L12.75 9.30999V12.69L18.26 7.17999Z" fill="currentColor"/>
            <path d="M15.908 4.02999C15.191 3.33289 14.3652 2.75734 13.463 2.32599C13.2348 2.21958 12.9957 2.13811 12.75 2.08299V7.18899L15.908 4.02999Z" fill="currentColor"/>
            <path d="M18.936 8.62399L12.75 14.811V17.689L19.5 10.939L19.632 10.807C19.456 10.0626 19.2233 9.33285 18.936 8.62399Z" fill="currentColor"/>
          </svg>
          EVERLOOM
        </h2>
        <p class="text-xs text-zinc-400 font-sans max-w-xs leading-relaxed">
          Timeless Fashion<br />For Modern Women
        </p>
      </div>

      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-4 text-zinc-300">Shop</h3>
        <ul class="space-y-2.5 text-xs text-zinc-400">
          <li><a href="/shop?category=all" class="hover:text-white transition-colors">All products</a></li>
          <li><a href="/shop?category=casual" class="hover:text-white transition-colors">Casual Wear</a></li>
          <li><a href="/shop?category=formal" class="hover:text-white transition-colors">Formal Wear</a></li>
          <li><a href="/shop?category=party" class="hover:text-white transition-colors">Party Wear</a></li>
          <li><a href="/shop?category=ethnic" class="hover:text-white transition-colors">Ethnic Wear</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest mb-4 text-zinc-300">Help</h3>
        <ul class="space-y-2.5 text-xs text-zinc-400">
          <li><a href="/support" class="hover:text-white transition-colors">Customer Service</a></li>
          <li><a href="/account" class="hover:text-white transition-colors">My Account</a></li>
          <li><a href="/stores" class="hover:text-white transition-colors">Find a Store</a></li>
          <li><a href="/privacy" class="hover:text-white transition-colors">Legal & Privacy</a></li>
        </ul>
      </div>

      <div class="space-y-4">
        <h3 class="text-xs font-bold uppercase tracking-widest text-zinc-300">Subscribe</h3>
        <p class="text-xs text-zinc-400 leading-relaxed">Get the latest updates and offers.</p>
        <form action="/subscribe" method="POST" class="flex max-w-sm">
          <input 
            type="email" 
            name="email" 
            placeholder="Email address" 
            required
            class="w-full bg-zinc-900 text-white text-xs px-4 py-3 border border-zinc-800 focus:outline-none focus:border-zinc-500 font-sans"
          />
          <button type="submit" class="bg-white text-black px-4 py-3 text-xs font-bold uppercase tracking-wider hover:bg-zinc-200 transition-colors">
            Join
          </button>
        </form>
      </div>

    </div>

    <div class="pt-6 text-center text-[10px] text-zinc-500 uppercase tracking-widest">
      &copy; <%= new Date().getFullYear() %> Everloom. All rights reserved.
    </div>
  </div>
</footer>
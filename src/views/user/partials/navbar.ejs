                </a>
                
                <a href="/account/wallet" class="flex items-center gap-3 px-4 py-2.5 text-xs font-medium text-brand-black hover:bg-brand-gray-50 transition-colors group">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-gray-400 group-hover:text-brand-black transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18-3a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6" />
                  </svg>
                  My Wallet
                </a>
              </div>

              <%# ── Refer & Earn divider item ── %>
              <div class="border-t border-brand-gray-100 py-1">
                <a href="/account/refer" class="flex items-center gap-3 px-4 py-2.5 text-xs font-medium text-brand-black hover:bg-brand-gray-50 transition-colors group">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-brand-gray-400 group-hover:text-brand-black transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">

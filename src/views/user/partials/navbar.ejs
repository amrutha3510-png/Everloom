      <%# Mobile — guest links %>
      <div class="pt-2 border-t border-brand-gray-50">
        <a href="/login" class="block w-full text-center border border-brand-black py-2 text-brand-black text-[10px] tracking-wider uppercase font-bold hover:bg-brand-black hover:text-white transition-all">
          Login
        </a>
      </div>
    <% } %>
  </div>
</nav>

<script>
  function toggleMobileMenu() {
    document.getElementById('mobileMenu').classList.toggle('hidden');
  }

  function toggleAccountMenu() {
    document.getElementById('accountDropdown').classList.toggle('hidden');
  }

  // Close account dropdown when clicking outside
  document.addEventListener('click', function (e) {
    const menu   = document.getElementById('accountMenu');
    const dropdown = document.getElementById('accountDropdown');
    if (menu && dropdown && !menu.contains(e.target)) {
      dropdown.classList.add('hidden');
    }
  });
</script>
    <a href="/shop" class="block py-1">Shop</a>
    <a href="/collections" class="block py-1">Collections</a>
    <a href="/support" class="block py-1">Support</a>

    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
      <%# Mobile — logged in links %>
      <div class="pt-2 border-t border-brand-gray-50 space-y-1">
        <a href="/account/profile" class="block py-1 hover:text-brand-black transition-colors">My Profile</a>
        <a href="/account/wallet" class="block py-1 hover:text-brand-black transition-colors">My Wallet</a>
        <a href="/account/addresses" class="block py-1 hover:text-brand-black transition-colors">Addresses</a>
        <a href="/account/referral" class="block py-1 hover:text-brand-black transition-colors">Referral Code</a>
        <a href="/account/refer" class="block py-1 hover:text-brand-black transition-colors">Refer &amp; Earn</a>
